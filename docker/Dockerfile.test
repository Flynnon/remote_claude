# Docker 测试镜像定义
# 用于验证 npm 包在不同环境下的完整性和功能可用性

FROM ubuntu:22.04

# 环境变量
ENV DEBIAN_FRONTEND=noninteractive \
    TZ=Asia/Shanghai \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PATH=/home/testuser/.local/bin:/home/testuser/bin:$PATH

# 设置时区
RUN ln -snf /usr/share/zoneinfo/$TZ /etc/localtime && echo $TZ > /etc/timezone

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    python3-venv \
    nodejs \
    npm \
    tmux \
    curl \
    git \
    build-essential \
    libevent-dev \
    libncurses5-dev \
    libncursesw5-dev \
    bison \
    pkg-config \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# 创建非 root 用户
RUN useradd -m -s /bin/bash testuser && \
    mkdir -p /home/testuser/.local/bin /home/testuser/bin && \
    chown -R testuser:testuser /home/testuser

# 切换到 testuser
USER testuser
WORKDIR /home/testuser

# 安装 uv（优先使用官方脚本）
RUN curl -LsSf https://astral.sh/uv/install.sh | sh || \
    pip3 install uv --break-system-packages || true

# 设置 uv 路径
ENV PATH=/home/testuser/.local/bin:$PATH

# 下载 Claude CLI（仅用于验证可执行性）
# 注意：不进行登录，仅下载二进制文件
RUN CLAUDA_VERSION=$(curl -s https://api.github.com/repos/anthropics/claude-cli/releases/latest | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/') && \
    curl -fsSL "https://github.com/anthropics/claude-cli/releases/download/${CLAUDA_VERSION}/claude-linux-amd64" -o /tmp/claude && \
    chmod +x /tmp/claude && \
    mv /tmp/claude /home/testuser/.local/bin/claude || \
    echo "Claude CLI download failed (expected in CI environment)"

# 不安装 Codex CLI（用户明确不需要）

# 创建测试结果目录
RUN mkdir -p /home/testuser/test-results

# 设置默认命令
CMD ["/bin/bash"]
